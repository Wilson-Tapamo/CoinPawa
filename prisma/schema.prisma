generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  username             String         @unique
  email                String?        @unique
  passwordHash         String
  avatarUrl            String?
  bannerUrl            String?
  role                 UserRole       @default(USER)
  isBanned             Boolean        @default(false)
  bannedAt             DateTime?
  banReason            String?
  bannedBy             String?
  isEmailVerified      Boolean        @default(false)
  emailVerifiedAt      DateTime?
  kycLevel             Int            @default(0)
  kycData              Json?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  failedLoginAttempts  Int            @default(0)
  lockedUntil          DateTime?
  twoFactorEnabled     Boolean        @default(false)
  twoFactorSecret      String?
  referrerId           String?
  referralEarningsSats BigInt         @default(0)
  totalDeposited       BigInt         @default(0)
  totalWithdrawn       BigInt         @default(0)
  totalWagered         BigInt         @default(0)
  totalWon             BigInt         @default(0)
  gamesPlayed          Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  adminActions         AdminAction[]  @relation("PerformedActions")
  targetedActions      AdminAction[]  @relation("TargetedUser")
  notes                AdminNote[]
  notifications        Notification[]
  referrer             User?          @relation("ReferralHistory", fields: [referrerId], references: [id])
  referrals            User[]         @relation("ReferralHistory")
  wallet               Wallet?

  @@index([role])
  @@index([isBanned])
  @@index([email])
  @@index([createdAt])
}

model Wallet {
  id                   String        @id @default(uuid())
  userId               String        @unique
  balanceSats          BigInt        @default(0)
  totalDepositedSats   BigInt        @default(0)
  totalWageredSats     BigInt        @default(0)
  lastFaucetClaim      DateTime?
  withdrawalAddress    String?
  withdrawalNetwork    String?       @default("TRC20")
  dailyWithdrawLimit   BigInt?
  monthlyWithdrawLimit BigInt?
  isWithdrawLocked     Boolean       @default(false)
  withdrawLockReason   String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  gameRounds           GameRound[]
  transactions         Transaction[]
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String    @id @default(uuid())
  walletId        String
  type            TxType
  amountSats      BigInt
  paymentRef      String    @unique
  status          TxStatus  @default(PENDING)
  cryptoCurrency  String?
  cryptoAmount    String?
  usdtAmount      String?
  exchangeRate    String?
  txHash          String?   @unique
  fromAddress     String?
  toAddress       String?
  blockNumber     Int?
  confirmations   Int?      @default(0)
  nowPaymentId    String?   @unique
  paymentUrl      String?
  paymentExpiry   DateTime?
  withdrawalFee   BigInt?
  netAmount       BigInt?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  riskScore       Float?    @default(0)
  isFlagged       Boolean   @default(false)
  flagReason      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  userIp          String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  wallet          Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
  @@index([type])
  @@index([nowPaymentId])
  @@index([createdAt])
  @@index([isFlagged])
  @@index([approvedBy])
}

model Game {
  id           String      @id @default(uuid())
  slug         String      @unique
  name         String
  type         GameType
  isActive     Boolean     @default(true)
  shortDesc    String?
  rules        String?
  imageUrl     String?
  config       Json?
  maxWinSats   BigInt?
  createdBy    String?
  houseEdge    Float       @default(2.0)
  totalBets    Int         @default(0)
  totalWagered BigInt      @default(0)
  totalPayout  BigInt      @default(0)
  playCount    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  rounds       GameRound[]

  @@index([isActive])
  @@index([type])
}

model GameRound {
  id               String      @id @default(uuid())
  walletId         String
  gameId           String
  status           RoundStatus @default(ACTIVE)
  betAmountSats    BigInt
  payoutAmountSats BigInt      @default(0)
  gameData         Json
  clientSeed       String
  serverSeedHash   String
  serverSeed       String?
  nonce            Int
  isSuspicious     Boolean     @default(false)
  suspicionReason  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  game             Game        @relation(fields: [gameId], references: [id])
  wallet           Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([gameId])
  @@index([createdAt])
  @@index([isSuspicious])
}

model SupportedCrypto {
  id            String   @id @default(uuid())
  symbol        String   @unique
  name          String
  network       String?
  isActive      Boolean  @default(true)
  minDepositUsd Float    @default(5.0)
  icon          String?
  orderIndex    Int      @default(0)
  totalDeposits Int      @default(0)
  totalVolume   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, orderIndex])
}

model PaymentSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model AdminAction {
  id               String          @id @default(uuid())
  adminId          String
  action           AdminActionType
  targetUserId     String?
  targetEntityType String?
  targetEntityId   String?
  details          Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime        @default(now())
  admin            User            @relation("PerformedActions", fields: [adminId], references: [id])
  targetUser       User?           @relation("TargetedUser", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model AdminNote {
  id          String   @id @default(uuid())
  userId      String
  authorId    String
  authorName  String
  note        String
  isImportant Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isImportant])
}

model SystemConfig {
  id             String   @id @default(uuid())
  key            String   @unique
  value          Json
  category       String
  description    String?
  isPublic       Boolean  @default(false)
  lastModifiedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
}

model SystemAlert {
  id         String    @id @default(uuid())
  type       String
  severity   String
  title      String
  message    String
  data       Json?
  isRead     Boolean   @default(false)
  readBy     String?
  readAt     DateTime?
  isResolved Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([isRead])
  @@index([isResolved])
  @@index([severity])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  icon      String?
  actionUrl String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
  @@index([type])
}

model DailyStats {
  id               String   @id @default(uuid())
  date             DateTime @unique @db.Date
  newUsers         Int      @default(0)
  activeUsers      Int      @default(0)
  totalDeposits    BigInt   @default(0)
  totalWithdrawals BigInt   @default(0)
  totalBets        BigInt   @default(0)
  totalWins        BigInt   @default(0)
  revenue          BigInt   @default(0)
  gamesPlayed      Int      @default(0)
  uniquePlayers    Int      @default(0)
  houseEdge        Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([date])
}

enum TxType {
  DEPOSIT
  DEPOSIT_BONUS
  WITHDRAW
  BET
  WIN
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

enum GameType {
  LOTTERY
  INSTANT
  SESSION
}

enum RoundStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum AdminActionType {
  BAN_USER
  UNBAN_USER
  APPROVE_WITHDRAWAL
  REJECT_WITHDRAWAL
  ADJUST_BALANCE
  EDIT_USER
  DELETE_TRANSACTION
  CHANGE_GAME_STATUS
  UPDATE_SETTINGS
  VIEW_SENSITIVE_DATA
}

enum NotificationType {
  DEPOSIT_CONFIRMED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  LOTTERY_WIN
  GAME_WIN_BIG
  SYSTEM_MESSAGE
}

// --- 3. HOMEPAGE EVENTS & PROMOTIONS ---
model HomepageEvent {
  id          String  @id @default(uuid())
  title       String
  description String? @db.Text
  imageUrl    String?
  buttonText  String?
  buttonLink  String?

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
}
